<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Review Jawaban | Tabeahan Cendekia</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root { --cream:#fff8f8; --gold:#c8a020; --dark:#7a1010; --red-deep:#5a0a0a; --muted:#9b6b6b; }
    *, *::before, *::after { box-sizing:border-box; }
    body { font-family:"DM Sans",sans-serif; background:var(--cream); color:var(--dark); min-height:100vh; }
    h1,h2,h3,h4 { font-family:"Playfair Display",serif; }

    /* ── Navbar ── */
    .nav { background:var(--red-deep); border-bottom:1px solid rgba(200,160,32,0.25); position:sticky; top:0; z-index:50; box-shadow:0 2px 12px rgba(90,10,10,0.18); }

    /* ── Stat bar ── */
    .stat-pill {
      display:inline-flex; align-items:center; gap:0.4rem;
      padding:0.45rem 0.9rem; border-radius:99px;
      font-size:0.72rem; font-weight:800;
    }
    .stat-benar  { background:rgba(21,128,61,0.1);  color:#15803d; border:1px solid rgba(21,128,61,0.2); }
    .stat-salah  { background:rgba(220,38,38,0.08); color:#b91c1c; border:1px solid rgba(220,38,38,0.15); }
    .stat-skor   { background:rgba(200,160,32,0.1); color:#92400e; border:1px solid rgba(200,160,32,0.25); }

    /* ── Filter tabs ── */
    .ftab { padding:0.35rem 0.9rem; border-radius:8px; font-size:0.65rem; font-weight:700; cursor:pointer; border:1px solid rgba(200,160,32,0.2); background:white; color:var(--muted); transition:all 0.2s; }
    .ftab.active, .ftab:hover { background:var(--red-deep); color:var(--gold); border-color:transparent; }

    /* ── Soal card ── */
    .soal-card {
      background:white; border-radius:14px;
      border:1px solid rgba(200,160,32,0.12);
      box-shadow:0 2px 12px rgba(90,10,10,0.05);
      overflow:hidden; transition:box-shadow 0.2s;
    }
    .soal-card:hover { box-shadow:0 6px 24px rgba(90,10,10,0.09); }
    .soal-card.benar { border-left:4px solid #16a34a; }
    .soal-card.salah { border-left:4px solid #dc2626; }

    .soal-header {
      padding:0.75rem 1.25rem;
      display:flex; align-items:center; justify-content:space-between; gap:0.5rem;
      border-bottom:1px solid rgba(200,160,32,0.08);
    }
    .soal-header.benar { background:rgba(21,128,61,0.04); }
    .soal-header.salah { background:rgba(220,38,38,0.03); }

    .nomor-badge {
      width:2rem; height:2rem; border-radius:8px; flex-shrink:0;
      display:flex; align-items:center; justify-content:center;
      font-family:"Playfair Display",serif; font-weight:900; font-size:0.8rem; color:white;
    }
    .nomor-badge.benar { background:#16a34a; }
    .nomor-badge.salah { background:#dc2626; }

    /* ── Opsi jawaban ── */
    .opsi-row {
      display:flex; align-items:flex-start; gap:0.75rem;
      padding:0.55rem 0.75rem; border-radius:8px;
      font-size:0.82rem; transition:background 0.15s;
    }
    .opsi-row.kunci  { background:rgba(21,128,61,0.08); border:1px solid rgba(21,128,61,0.2); }
    .opsi-row.salah-user { background:rgba(220,38,38,0.06); border:1px solid rgba(220,38,38,0.18); }
    .opsi-row.normal { background:rgba(200,160,32,0.03); border:1px solid rgba(200,160,32,0.1); }

    .opsi-huruf {
      width:1.5rem; height:1.5rem; border-radius:6px; flex-shrink:0;
      display:flex; align-items:center; justify-content:center;
      font-size:0.65rem; font-weight:800; text-transform:uppercase;
    }
    .opsi-huruf.kunci     { background:#16a34a; color:white; }
    .opsi-huruf.salah-user { background:#dc2626; color:white; }
    .opsi-huruf.normal    { background:rgba(200,160,32,0.15); color:var(--muted); }

    /* ── Keterangan box ── */
    .keterangan-box {
      background:linear-gradient(135deg, rgba(200,160,32,0.06), rgba(200,160,32,0.03));
      border:1px solid rgba(200,160,32,0.25);
      border-radius:10px; padding:1rem 1.25rem;
      position:relative;
    }
    .keterangan-box::before {
      content:'💡';
      position:absolute; top:-0.6rem; left:1rem;
      background:var(--cream); padding:0 0.25rem;
      font-size:0.85rem;
    }
    .keterangan-label {
      font-size:0.55rem; font-weight:800; text-transform:uppercase;
      letter-spacing:0.12em; color:var(--gold); margin-bottom:0.5rem;
      display:block;
    }
    .keterangan-text {
      font-size:0.82rem; line-height:1.75; color:var(--dark);
      white-space:pre-wrap;   /* jaga enter/baris baru */
    }

    /* ── Scroll to top ── */
    #scrollTop {
      position:fixed; bottom:1.5rem; right:1.5rem; z-index:40;
      width:2.5rem; height:2.5rem; border-radius:50%;
      background:var(--red-deep); color:var(--gold);
      border:none; cursor:pointer; font-size:1rem;
      display:flex; align-items:center; justify-content:center;
      box-shadow:0 4px 12px rgba(90,10,10,0.25);
      transition:all 0.2s; opacity:0; pointer-events:none;
    }
    #scrollTop.show { opacity:1; pointer-events:auto; }
    #scrollTop:hover { background:var(--gold); color:white; }
  </style>
</head>
<body>

<!-- NAVBAR -->
<nav class="nav">
  <div class="max-w-4xl mx-auto px-4 py-3.5 flex justify-between items-center">
    <div class="flex items-center gap-2.5">
      <img src="/asset/logo.png" alt="Logo" class="h-8 w-auto">
      <span style="font-family:'Playfair Display',serif;color:white;font-size:0.95rem;font-weight:700">
        Tabeahan <span style="color:var(--gold)">Cendekia</span>
      </span>
    </div>
    <a href="/dashboardPembayaranUjian"
      style="background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.75);border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:0.35rem 1rem;font-size:0.72rem;font-weight:700;text-decoration:none;transition:all 0.2s"
      onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='rgba(255,255,255,0.75)'">
      ← Kembali
    </a>
  </div>
</nav>

<!-- MAIN -->
<div class="max-w-4xl mx-auto px-4 py-8">

  <!-- Header -->
  <div class="mb-6">
    <p style="font-size:0.6rem;font-weight:800;text-transform:uppercase;letter-spacing:0.15em;color:var(--muted);margin-bottom:0.35rem">
      <%= paket %> · Try Out #<%= nomor_to %>
    </p>
    <h1 style="font-size:1.75rem;font-weight:900;color:var(--dark);margin:0 0 0.35rem">
      Review Jawaban
    </h1>
    <% if (tglSelesai) { %>
    <p style="font-size:0.75rem;color:var(--muted)">
      Diselesaikan pada <%= new Date(tglSelesai).toLocaleDateString('id-ID', {weekday:'long', day:'2-digit', month:'long', year:'numeric'}) %>
    </p>
    <% } %>
  </div>

  <!-- Stat bar -->
  <div class="flex flex-wrap gap-2.5 mb-5">
    <span class="stat-pill stat-benar">✅ <%= totalBenar %> Benar</span>
    <span class="stat-pill stat-salah">❌ <%= totalSalah %> Salah</span>
    <span class="stat-pill stat-skor">🎯 Skor <%= skor %></span>
    <span class="stat-pill" style="background:rgba(90,10,10,0.06);color:var(--dark);border:1px solid rgba(90,10,10,0.1)">
      📄 <%= totalSoal %> Soal
    </span>
  </div>

  <!-- Skor bar visual -->
  <div class="mb-6">
    <div style="height:6px;background:rgba(200,160,32,0.12);border-radius:99px;overflow:hidden">
      <div style="height:100%;width:<%= skor %>%;background:linear-gradient(90deg,#16a34a,var(--gold));border-radius:99px;transition:width 1s"></div>
    </div>
  </div>

  <!-- Filter -->
  <div class="flex items-center gap-2 mb-5 flex-wrap">
    <span style="font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted)">Tampilkan:</span>
    <button class="ftab active" data-filter="all">Semua (<%= totalSoal %>)</button>
    <button class="ftab" data-filter="benar">✅ Benar (<%= totalBenar %>)</button>
    <button class="ftab" data-filter="salah">❌ Salah (<%= totalSalah %>)</button>
  </div>

  <!-- List Soal -->
  <div class="space-y-5" id="soalList">
  <% soalRows.forEach((item, idx) => {
       const statusClass = item.is_benar ? 'benar' : 'salah';
       const opsiMap = {
         a: item.opsi_a, b: item.opsi_b, c: item.opsi_c,
         d: item.opsi_d, e: item.opsi_e
       };
       const kunciLower     = (item.kunci     || '').toLowerCase();
       const jawabanLower   = (item.jawaban_user || '').toLowerCase();
  %>
  <div class="soal-card <%= statusClass %>" data-status="<%= statusClass %>">

    <!-- Card header -->
    <div class="soal-header <%= statusClass %>">
      <div style="display:flex;align-items:center;gap:0.75rem">
        <div class="nomor-badge <%= statusClass %>"><%= idx + 1 %></div>
        <div>
          <span style="font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted)">Soal #<%= item.nomor_urut %></span>
          <% if (!item.is_benar) { %>
          <p style="font-size:0.65rem;color:#b91c1c;font-weight:700;margin:0">
            Jawabanmu: <strong><%= jawabanLower.toUpperCase() %></strong> · Kunci: <strong><%= kunciLower.toUpperCase() %></strong>
          </p>
          <% } %>
        </div>
      </div>
      <% if (item.is_benar) { %>
        <span style="font-size:0.75rem;color:#15803d;font-weight:800">✅ Benar</span>
      <% } else { %>
        <span style="font-size:0.75rem;color:#b91c1c;font-weight:800">❌ Salah</span>
      <% } %>
    </div>

    <!-- Body soal -->
    <div class="p-5 space-y-4">

      <!-- Teks soal -->
      <p style="font-size:0.9rem;line-height:1.7;color:var(--dark);font-weight:500"><%= item.soal %></p>

      <!-- Opsi jawaban -->
      <div class="space-y-2">
      <% ['a','b','c','d','e'].forEach(huruf => { %>
        <%
          let rowClass   = 'normal';
          let hurufClass = 'normal';
          let icon       = '';

          if (huruf === kunciLower) {
            rowClass   = 'kunci';
            hurufClass = 'kunci';
            icon       = '✅ ';
          } else if (huruf === jawabanLower && !item.is_benar) {
            rowClass   = 'salah-user';
            hurufClass = 'salah-user';
            icon       = '❌ ';
          }
        %>
        <div class="opsi-row <%= rowClass %>">
          <div class="opsi-huruf <%= hurufClass %>"><%= huruf %></div>
          <span style="font-size:0.82rem;line-height:1.5;flex:1"><%= icon %><%= opsiMap[huruf] || '-' %></span>
        </div>
      <% }) %>
      </div>

      <!-- Keterangan Jawaban -->
      <% if (item.pembahasan && item.pembahasan.trim() !== '') { %>
      <div class="keterangan-box">
        <span class="keterangan-label">Pembahasan</span>
        <p class="keterangan-text"><%= item.pembahasan %></p>
      </div>
      <% } %>

    </div>
  </div>
  <% }) %>
  </div>

  <!-- Empty state kalau filter kosong -->
  <div id="emptyFilter" style="display:none;text-align:center;padding:3rem">
    <div style="font-size:2.5rem;opacity:0.2;margin-bottom:0.75rem">🔍</div>
    <p style="color:var(--muted);font-weight:600">Tidak ada soal dengan filter ini.</p>
  </div>

  <div class="mt-8 flex justify-center">
    <a href="/dashboardPembayaranUjian"
      style="background:linear-gradient(135deg,var(--red-deep),#6b1a1a);color:white;padding:0.75rem 2rem;border-radius:10px;font-size:0.8rem;font-weight:700;text-decoration:none;letter-spacing:0.05em">
      ← Kembali ke Dashboard
    </a>
  </div>

  <p style="margin-top:2rem;text-align:center;font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:rgba(155,107,107,0.35)">
    Tabeahan Cendekia
  </p>

</div>

<!-- Scroll to top -->
<button id="scrollTop" title="Ke atas">↑</button>

<script>
  // Filter tabs
  document.querySelectorAll('.ftab').forEach(tab => {
    tab.addEventListener('click', function () {
      document.querySelectorAll('.ftab').forEach(t => t.classList.remove('active'));
      this.classList.add('active');
      const filter = this.dataset.filter;
      let shown = 0;
      document.querySelectorAll('.soal-card').forEach(card => {
        const match = filter === 'all' || card.dataset.status === filter;
        card.style.display = match ? '' : 'none';
        if (match) shown++;
      });
      document.getElementById('emptyFilter').style.display = shown === 0 ? '' : 'none';
    });
  });

  // Scroll to top button
  const scrollBtn = document.getElementById('scrollTop');
  window.addEventListener('scroll', () => {
    scrollBtn.classList.toggle('show', window.scrollY > 400);
  });
  scrollBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>

</body>
</html>
