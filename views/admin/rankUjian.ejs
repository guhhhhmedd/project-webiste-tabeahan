<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ranking Peserta | Tabeahan Cendekia</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-50 p-8">
  <div class="max-w-6xl mx-auto bg-white p-6 rounded-lg shadow">
    <h1 class="text-2xl font-bold text-gray-800 mb-2">🏆 Papan Peringkat Ujian</h1>
    <p class="text-sm text-gray-500 mb-6">Diurutkan berdasarkan Total Skor → Nilai TKP → Nilai TIU → Nilai TWK</p>

    <table class="w-full text-left border-collapse">
  <thead>
    <tr class="bg-gray-100 border-b border-gray-200 text-xs font-bold uppercase text-gray-600">
      <th class="p-3">Rank</th>
      <th class="p-3">Peserta</th>
      <th class="p-3">Paket / TO</th>
      <th class="p-3 text-center">Jawaban Benar</th>
      <th class="p-3 text-center">Total Skor</th>
      <th class="p-3 text-right">Tanggal Selesai</th>
    </tr>
  </thead>
  <tbody>
    <% rankings.forEach(r => { %>
    <tr class="border-b border-gray-100 hover:bg-gray-50 text-sm">
      <td class="p-3 font-bold text-blue-600">#<%= r.ranking %></td>
      <td class="p-3">
        <p class="font-semibold text-gray-800"><%= r.username %></p>
        <p class="text-xs text-gray-400"><%= r.email %></p>
      </td>
      <td class="p-3 font-medium text-gray-700"><%= r.paket %> (TO #<%= r.nomor_to %>)</td>
      <td class="p-3 text-center text-gray-600"><%= r.jml_benar %> / <%= r.jml_soal %></td>
      <td class="p-3 text-center font-bold text-lg text-emerald-600"><%= r.total_skor %></td>
      <td class="p-3 text-right text-xs text-gray-500">
        <%= new Date(r.tgl_selesai).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %>
      </td>
    </tr>
    <% }) %>
  </tbody>
</table>
  </div>
</body>
</html>