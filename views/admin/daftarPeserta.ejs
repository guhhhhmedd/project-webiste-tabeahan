<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daftar Peserta | Tabeahan Cendekia</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root { --cream:#fff8f8; --gold:#c8a020; --dark:#7a1010; --red-deep:#5a0a0a; --muted:#9b6b6b; }
    *, *::before, *::after { box-sizing:border-box; }
    body { font-family:"DM Sans",sans-serif; background:var(--cream); color:var(--dark); min-height:100vh; }
    h1,h2,h3,h4 { font-family:"Playfair Display",serif; }

    .adm-nav { background:var(--red-deep); border-bottom:1px solid rgba(200,160,32,0.25); position:sticky; top:0; z-index:50; box-shadow:0 2px 12px rgba(90,10,10,0.18); }
    .adm-nav-link { color:rgba(255,255,255,0.5); font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; transition:color 0.2s; }
    .adm-nav-link:hover, .adm-nav-link.active { color:var(--gold); }

    .tbl-card { background:white; border-radius:12px; border:1px solid rgba(200,160,32,0.12); box-shadow:0 2px 16px rgba(90,10,10,0.06); overflow:hidden; }
    .tbl-hd { background:linear-gradient(135deg,var(--red-deep),#6b1a1a); padding:0.875rem 1.25rem; border-bottom:1px solid rgba(200,160,32,0.15); }
    .tbl-hd h3 { color:white; font-size:0.875rem; margin:0; font-family:"Playfair Display",serif; }

    table { width:100%; border-collapse:collapse; }
    thead tr { background:rgba(90,10,10,0.04); border-bottom:2px solid rgba(200,160,32,0.15); }
    thead th { padding:0.75rem 1.25rem; font-size:0.6rem; font-weight:800; text-transform:uppercase; letter-spacing:0.12em; color:var(--muted); text-align:left; }
    tbody tr { border-bottom:1px solid rgba(200,160,32,0.07); transition:background 0.15s; }
    tbody tr:hover { background:rgba(200,160,32,0.03); }
    tbody td { padding:1rem 1.25rem; vertical-align:top; }

    .badge { display:inline-block; padding:0.2rem 0.6rem; border-radius:5px; font-size:0.6rem; font-weight:800; text-transform:uppercase; letter-spacing:0.06em; }
    .badge-lunas   { background:rgba(21,128,61,0.1);   color:#15803d; border:1px solid rgba(21,128,61,0.2); }
    .badge-pending { background:rgba(200,160,32,0.1);  color:#a16207; border:1px solid rgba(200,160,32,0.25); }
    .badge-ditolak { background:rgba(220,38,38,0.08);  color:#b91c1c; border:1px solid rgba(220,38,38,0.18); }
    .badge-selesai { background:rgba(122,16,16,0.07);  color:var(--dark); border:1px solid rgba(122,16,16,0.15); }
    .badge-idle    { background:rgba(155,107,107,0.08);color:var(--muted); border:1px solid rgba(155,107,107,0.15); }

    .stat-box { background:white; border:1px solid rgba(200,160,32,0.15); border-left:3px solid var(--gold); border-radius:10px; padding:0.75rem 1.25rem; }

    .paket-group { border:1px solid rgba(200,160,32,0.15); border-radius:10px; overflow:hidden; margin-bottom:0.5rem; }
    .paket-group:last-child { margin-bottom:0; }
    .paket-group-header { background:rgba(90,10,10,0.04); padding:0.5rem 0.75rem; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid rgba(200,160,32,0.1); }

    .to-row { padding:0.5rem 0.75rem; display:flex; align-items:center; justify-content:space-between; gap:0.5rem; border-bottom:1px solid rgba(200,160,32,0.07); flex-wrap:wrap; }
    .to-row:last-child { border-bottom:none; }

    .to-num { width:1.75rem; height:1.75rem; border-radius:6px; display:inline-flex; align-items:center; justify-content:center; font-family:"Playfair Display",serif; font-weight:900; font-size:0.7rem; color:white; flex-shrink:0; }

    .btn-verify { background:#15803d; color:white; border:none; padding:0.3rem 0.65rem; border-radius:6px; font-size:0.62rem; font-weight:700; cursor:pointer; transition:background 0.2s; white-space:nowrap; }
    .btn-verify:hover { background:#166534; }
    .btn-reject  { background:var(--red-deep); color:white; border:none; padding:0.3rem 0.65rem; border-radius:6px; font-size:0.62rem; font-weight:700; cursor:pointer; transition:background 0.2s; white-space:nowrap; }
    .btn-reject:hover  { background:#3a0000; }
    .btn-reset   { background:#ca8a04; color:white; border:none; padding:0.3rem 0.65rem; border-radius:6px; font-size:0.62rem; font-weight:700; cursor:pointer; transition:background 0.2s; white-space:nowrap; }
    .btn-reset:hover   { background:#a16207; }
    .btn-bukti   { background:rgba(200,160,32,0.08); color:var(--dark); border:1px solid rgba(200,160,32,0.2); padding:0.3rem 0.65rem; border-radius:6px; font-size:0.62rem; font-weight:700; cursor:pointer; transition:all 0.2s; text-decoration:none; display:inline-block; white-space:nowrap; }
    .btn-bukti:hover   { background:rgba(200,160,32,0.16); }


    .filter-tab { padding:0.35rem 0.9rem; border-radius:8px; font-size:0.65rem; font-weight:700; cursor:pointer; border:1px solid rgba(200,160,32,0.2); background:white; color:var(--muted); transition:all 0.2s; }
    .filter-tab.active, .filter-tab:hover { background:var(--red-deep); color:var(--gold); border-color:transparent; }
  </style>
</head>
<body>

<!-- ===== NAVBAR ===== -->
<nav class="adm-nav">
  <div class="max-w-7xl mx-auto px-4 md:px-8 py-3.5 flex justify-between items-center">
    <div class="flex items-center gap-6">
      <div class="flex items-center gap-2.5">
        <img src="../asset/logo.png" alt="Logo" class="h-9 w-auto">
        <div>
          <span style="font-family:'Playfair Display',serif;color:white;font-size:1rem;font-weight:700;display:block;line-height:1.2">
            Tabeahan <span style="color:var(--gold)">Cendekia</span>
          </span>
          <span style="display:inline-block;background:var(--gold);color:#3a0000;font-size:0.55rem;padding:0.1rem 0.45rem;border-radius:4px;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;margin-top:2px">
            Administrator
          </span>
        </div>
      </div>
      <div class="hidden md:flex gap-5">
        <a href="/dashboardAdmin" class="adm-nav-link">Dashboard</a>
        <a href="/admin/daftarPeserta" class="adm-nav-link active">Peserta Ujian</a>
        <a href="/admin/anggota" class="adm-nav-link">Anggota Offline</a>
      </div>
    </div>
    <a href="/logout"
      style="background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.7);border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:0.35rem 1rem;font-size:0.75rem;font-weight:700;transition:all 0.2s;text-decoration:none"
      onmouseover="this.style.background='rgba(200,160,32,0.2)';this.style.color='#c8a020'"
      onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.color='rgba(255,255,255,0.7)'">
      Logout
    </a>
  </div>
</nav>

<!-- ===== MAIN ===== -->
<div class="max-w-7xl mx-auto px-4 py-8">

  <!-- Header -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
    <div>
      <a href="/dashboardAdmin"
        class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest transition mb-2"
        style="color:var(--muted)"
        onmouseover="this.style.color='var(--dark)'" onmouseout="this.style.color='var(--muted)'">
        ← Dashboard
      </a>
      <h1 style="font-size:1.75rem;font-weight:900;color:var(--dark);margin:0">Daftar Peserta</h1>
      <p style="font-size:0.875rem;color:var(--muted);margin-top:0.25rem">Verifikasi pembayaran per Try Out</p>
    </div>
    <div class="flex items-center gap-3 flex-wrap">
      <%
        let totalPending = 0;
        users.forEach(u => {
          const pays = paymentsMap[u.id] || [];
          totalPending += pays.filter(p => p.status.toUpperCase() === 'PENDING').length;
        });
      %>
      <% if (totalPending > 0) { %>
      <div class="stat-box" style="border-left-color:#a16207">
        <span style="display:block;font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted)">Menunggu</span>
        <span style="font-size:1.5rem;font-weight:900;font-family:'Playfair Display',serif;color:#a16207"><%= totalPending %></span>
      </div>
      <% } %>
      <div class="stat-box">
        <span style="display:block;font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted)">Total Peserta</span>
        <span style="font-size:1.5rem;font-weight:900;font-family:'Playfair Display',serif;color:var(--dark)"><%= users.length %></span>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <% if (typeof message !== 'undefined' && message) { %>
  <div class="mb-4 px-4 py-3 rounded-lg text-sm font-semibold flex items-center gap-2"
    style="background:rgba(21,128,61,0.08);border:1px solid rgba(21,128,61,0.2);color:#15803d">
    ✅ <%= message %>
  </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="mb-4 px-4 py-3 rounded-lg text-sm font-semibold flex items-center gap-2"
    style="background:rgba(220,38,38,0.07);border:1px solid rgba(220,38,38,0.18);color:#b91c1c">
    ❌ <%= error %>
  </div>
  <% } %>

  <!-- Search + Filter -->
  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 mb-4 flex-wrap">
    <!-- Search -->
    <div class="relative flex-1 min-w-[200px] max-w-xs">
      <input type="text" id="searchPeserta" placeholder="Cari nama / email..."
        style="width:100%;font-size:0.75rem;border:1px solid rgba(200,160,32,0.25);border-radius:6px;padding:0.4rem 0.75rem 0.4rem 2rem;outline:none;font-family:'DM Sans',sans-serif;color:var(--dark);background:white;transition:border-color 0.2s"
        onfocus="this.style.borderColor='var(--gold)'" onblur="this.style.borderColor='rgba(200,160,32,0.25)'">
      <span style="position:absolute;left:0.6rem;top:50%;transform:translateY(-50%);font-size:0.75rem;pointer-events:none">🔍</span>
    </div>
    <!-- Filter tabs -->
    <div class="flex items-center gap-2 flex-wrap">
      <span style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted)">Filter:</span>
      <button class="filter-tab active" data-filter="all">Semua</button>
      <button class="filter-tab" data-filter="pending">⏳ Ada Pending</button>
      <button class="filter-tab" data-filter="active">✅ Ada Aktif</button>
    </div>
  </div>
  <!-- Counter hasil pencarian -->
  <p id="searchCount" style="font-size:0.65rem;color:var(--muted);margin-bottom:0.5rem;display:none"></p>

  <!-- Tabel -->
  <div class="tbl-card">
    <div class="tbl-hd flex items-center justify-between">
      <h3>👥 Data Peserta & Pembayaran Per Try Out</h3>
      <span style="font-size:0.65rem;color:rgba(255,255,255,0.5)"><%= users.length %> peserta</span>
    </div>

    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Peserta</th>
            <th>Reset Password</th>
            <th>Status Ujian</th>
            <th>Pembayaran Per TO</th>
            <th style="text-align:right">Aksi</th>
          </tr>
        </thead>
        <tbody>

        <%
          /* ═══════════════════════════════
             LOOP UTAMA — satu baris per user
             ═══════════════════════════════ */
          users.forEach((u, i) => {
            const userPayments = paymentsMap[u.id] || [];

            /* Group by paket */
            const grouped = {};
            userPayments.forEach(pay => {
              if (!grouped[pay.paket]) grouped[pay.paket] = [];
              grouped[pay.paket].push(pay);
            });

            const hasPending = userPayments.some(p => p.status.toUpperCase() === 'PENDING');
            const hasActive  = userPayments.some(p => p.status.toUpperCase() === 'LUNAS');
        %>
        <tr class="peserta-row"
          data-has-pending="<%= hasPending ? '1' : '0' %>"
          data-has-active="<%= hasActive ? '1' : '0' %>"
          data-username="<%= u.username.toLowerCase() %>"
          data-email="<%= u.email.toLowerCase() %>">

          <!-- # -->
          <td>
            <span style="font-size:0.75rem;font-weight:700;color:rgba(155,107,107,0.5)"><%= i + 1 %></span>
          </td>

          <!-- Info User -->
          <td>
            <div class="flex items-center gap-2.5">
              <div style="width:2rem;height:2rem;border-radius:50%;background:linear-gradient(135deg,var(--red-deep),#6b1a1a);display:flex;align-items:center;justify-content:center;color:var(--gold);font-size:0.75rem;font-weight:800;flex-shrink:0">
                <%= u.username.charAt(0).toUpperCase() %>
              </div>
              <div>
                <p style="font-size:0.875rem;font-weight:700;color:var(--dark);margin:0"><%= u.username %></p>
                <p style="font-size:0.7rem;color:var(--muted);margin:0;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= u.email %></p>
                <p style="font-size:0.6rem;color:rgba(155,107,107,0.5);margin:0">ID #<%= u.id %></p>
              </div>
            </div>
          </td>

          <!-- Reset Password -->
          <td>
            <form action="/admin/reset-password" method="POST" class="confirm-reset-pw flex items-center gap-1.5" data-username="<%= u.username %>">
              <input type="hidden" name="userId" value="<%= u.id %>">
              <input type="text" name="newPassword" placeholder="Password baru..."
                style="font-size:0.7rem;border:1px solid rgba(200,160,32,0.25);border-radius:4px;padding:0.25rem 0.5rem;width:110px;outline:none;font-family:'DM Sans',sans-serif;color:var(--dark)"
                minlength="6" required>
              <button type="submit"
                style="background:var(--red-deep);color:var(--gold);border:none;padding:0.25rem 0.5rem;border-radius:4px;font-size:0.65rem;font-weight:700;cursor:pointer;white-space:nowrap;transition:opacity 0.2s"
                onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
                🔑 Reset
              </button>
            </form>
          </td>

          <!-- Status Ujian -->
          <td>
            <% if (u.status_ujian === 'SELESAI') { %>
              <span class="badge badge-selesai">🎓 Selesai</span>
              <p style="font-size:0.75rem;font-weight:800;color:var(--gold);margin-top:0.25rem">Skor: <%= u.skor || 0 %></p>
            <% } else if (u.status_ujian === 'SEDANG_UJIAN') { %>
              <span class="badge badge-pending">⏱ Ujian</span>
            <% } else { %>
              <span class="badge badge-idle">Idle</span>
            <% } %>
          </td>

          <!-- Pembayaran Per TO -->
          <td style="min-width:320px">
            <% if (userPayments.length === 0) { %>
              <p style="font-size:0.7rem;font-style:italic;color:var(--muted)">Belum ada pembayaran</p>
            <% } else { %>

              <%
                /* ─────────────────────────────────
                   LOOP PAKET — group per nama paket
                   ───────────────────────────────── */
                Object.keys(grouped).forEach(namaP => {
                  const paysInPaket = grouped[namaP];
                  paysInPaket.sort((a, b) => a.nomor_to - b.nomor_to);
                  const lCount = paysInPaket.filter(p => p.status.toUpperCase() === 'LUNAS').length;
                  const pCount = paysInPaket.filter(p => p.status.toUpperCase() === 'PENDING').length;
                  const dCount = paysInPaket.filter(p => p.status.toUpperCase() === 'DITOLAK').length;
              %>
              <div class="paket-group">

                <!-- Header grup paket -->
                <div class="paket-group-header">
                  <span style="font-size:0.7rem;font-weight:800;color:var(--dark)"><%= namaP %></span>
                  <div style="display:flex;gap:0.25rem;flex-wrap:wrap">
                    <% if (lCount > 0) { %><span class="badge badge-lunas"><%= lCount %> Aktif</span><% } %>
                    <% if (pCount > 0) { %><span class="badge badge-pending"><%= pCount %> Pending</span><% } %>
                    <% if (dCount > 0) { %><span class="badge badge-ditolak"><%= dCount %> Tolak</span><% } %>
                  </div>
                </div>

                <%
                  /* ─────────────────────────
                     LOOP TO — baris per nomor TO
                     ───────────────────────── */
                  paysInPaket.forEach(pay => {
                    const st = pay.status.toUpperCase();
                %>
                <div class="to-row">

                  <!-- Nomor TO + badge status -->
                  <div style="display:flex;align-items:center;gap:0.6rem;flex-shrink:0">
                    <div class="to-num" style="background:<%= st==='LUNAS'?'#16a34a':st==='PENDING'?'#a16207':st==='DITOLAK'?'#b91c1c':'var(--muted)' %>">
                      <%= pay.nomor_to %>
                    </div>
                    <div>
                      <p style="font-size:0.7rem;font-weight:700;color:var(--dark);margin:0;line-height:1.2">TO #<%= pay.nomor_to %></p>
                      <span class="badge <%= st==='LUNAS'?'badge-lunas':st==='PENDING'?'badge-pending':st==='DITOLAK'?'badge-ditolak':'badge-idle' %>"
                        style="margin-top:2px;display:inline-block">
                        <%= pay.status %>
                      </span>
                    </div>
                  </div>

                  <!-- Token -->
                  <% if (pay.token_ujian) { %>
                  <div style="text-align:center;flex-shrink:0">
                    <p style="font-size:0.55rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--muted);margin:0">Token</p>
                    <span style="font-family:monospace;font-size:0.7rem;font-weight:800;color:var(--gold)"><%= pay.token_ujian %></span>
                  </div>
                  <% } %>

                  <!-- Tombol aksi -->
                  <div style="display:flex;align-items:center;gap:0.35rem;flex-wrap:wrap;flex-shrink:0">
                    <% if (pay.bukti_transfer) { %>
                      <a href="/uploads/bukti/<%= pay.bukti_transfer %>" target="_blank" class="btn-bukti">📄 Bukti</a>
                    <% } %>
                    <% if (st === 'PENDING') { %>
                      <form action="/admin/verify/<%= pay.id %>" method="POST" class="confirm-verify" style="display:inline">
                        <button type="submit" class="btn-verify">✅ Verifikasi</button>
                      </form>
                      <form action="/admin/reject/<%= pay.id %>" method="POST" class="confirm-reject" style="display:inline">
                        <button type="submit" class="btn-reject">❌ Tolak</button>
                      </form>
                    <% } %>
                    <% if (st === 'LUNAS' || st === 'SELESAI') { %>
                      <form action="/admin/reset-ujian-user" method="POST" class="confirm-reset" style="display:inline">
                        <input type="hidden" name="userIdTarget" value="<%= u.id %>">
                        <input type="hidden" name="paket_pilihan" value="<%= pay.paket %>">
                        <input type="hidden" name="nomor_to" value="<%= pay.nomor_to %>">
                        <button type="submit" class="btn-reset">🔄 Reset</button>
                      </form>
                    <% } %>
                    <form action="/admin/delete-payment" method="POST" class="confirm-delete-payment" style="display:inline">
                      <input type="hidden" name="paymentId" value="<%= pay.id %>">
                      <button type="submit"
                        style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:0.85rem;padding:0.2rem 0.35rem;border-radius:5px;transition:all 0.2s"
                        onmouseover="this.style.background='rgba(220,38,38,0.08)';this.style.color='#b91c1c'"
                        onmouseout="this.style.background='none';this.style.color='var(--muted)'"
                        title="Hapus riwayat TO ini">🗑️</button>
                    </form>
                  </div>

                </div>
                <% }) /* ── END LOOP TO ── */ %>

              </div>
              <% }) /* ── END LOOP PAKET ── */ %>

            <% } /* end else userPayments.length */ %>
          </td>

          <!-- Hapus Akun -->
          <td style="text-align:right;white-space:nowrap">
            <form action="/deleteAccountFromAdmin" method="POST" class="confirm-delete-admin" style="display:inline">
              <input type="hidden" name="id" value="<%= u.id %>">
              <button type="submit"
                style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:1rem;padding:0.375rem;border-radius:6px;transition:all 0.2s"
                onmouseover="this.style.background='rgba(220,38,38,0.08)';this.style.color='#b91c1c'"
                onmouseout="this.style.background='none';this.style.color='var(--muted)'">
                🗑️
              </button>
            </form>
          </td>

        </tr>
        <% }) /* ══ END LOOP UTAMA ══ */ %>

        </tbody>
      </table>
    </div><!-- end overflow-x-auto -->

    <% if (users.length === 0) { %>
    <div style="padding:4rem;text-align:center">
      <div style="font-size:2.5rem;opacity:0.2;margin-bottom:0.75rem">👤</div>
      <p style="color:var(--muted);font-size:0.875rem;font-weight:600">Belum ada peserta terdaftar.</p>
    </div>
    <% } %>

  </div><!-- end tbl-card -->

  <p style="margin-top:1.5rem;text-align:center;font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:rgba(155,107,107,0.4)">
    Tabeahan Cendekia · Admin Panel
  </p>

</div><!-- end main -->

<script>
document.addEventListener('DOMContentLoaded', function() {
  // ── State ──
  let activeFilter = 'all';
  let searchQuery = '';

  const rows = document.querySelectorAll('.peserta-row');
  const counter = document.getElementById('searchCount');
  const searchInput = document.getElementById('searchPeserta');
  const filterTabs = document.querySelectorAll('.filter-tab');

  function applyFilters() {
    let visible = 0;

    rows.forEach(row => {
      // Logika Filter Tab
      const hasPending = row.getAttribute('data-has-pending') === '1';
      const hasActive = row.getAttribute('data-has-active') === '1';

      let matchFilter = false;
      if (activeFilter === 'all') {
        matchFilter = true;
      } else if (activeFilter === 'pending') {
        matchFilter = hasPending;
      } else if (activeFilter === 'active') {
        matchFilter = hasActive;
      }

      // Logika Search
      const textName = row.getAttribute('data-username') || '';
      const textEmail = row.getAttribute('data-email') || '';
      const matchSearch = searchQuery === '' || 
                          textName.includes(searchQuery) || 
                          textEmail.includes(searchQuery);

      // Eksekusi Tampilan
      if (matchFilter && matchSearch) {
        row.style.display = '';
        visible++;
      } else {
        row.style.display = 'none';
      }
    });

    // Update Counter
    if (searchQuery !== '') {
      counter.style.display = 'block';
      counter.textContent = `${visible} peserta ditemukan untuk "${searchQuery}"`;
    } else {
      counter.style.display = 'none';
    }
  }

  // Event Listener untuk Tabs
  filterTabs.forEach(tab => {
    tab.addEventListener('click', function() {
      // Update UI Tombol
      filterTabs.forEach(t => t.classList.remove('active'));
      this.classList.add('active');

      // Update State & Filter
      activeFilter = this.getAttribute('data-filter');
      applyFilters();
    });
  });

  // Event Listener untuk Search
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      searchQuery = this.value.toLowerCase().trim();
      applyFilters();
    });
  }

  // --- Logika Konfirmasi (Verify, Reject, dll tetap sama) ---
  // ... (masukkan kode confirm-verify dkk kamu di sini)
});
</script>

</body>
</html>
