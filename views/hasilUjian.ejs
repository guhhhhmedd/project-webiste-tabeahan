<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hasil Ujian - Tabeahan Cendekia</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    :root { --gold:#b8924a; --dark:#1a1008; --cream:#fdfaf5; }
    body { font-family:"DM Sans",sans-serif; background:var(--cream); color:var(--dark); }
    .font-display { font-family:"Playfair Display",serif; }
    .card-grad { background:linear-gradient(135deg,#fff 0%,#fcf8f0 100%); border:1px solid #e8dec9; }
    .skor-circle {
      width:180px; height:180px; border-radius:50%;
      background:white; border:8px solid var(--gold);
      display:flex; flex-direction:column; align-items:center; justify-content:center;
      box-shadow:0 10px 30px rgba(184,146,74,0.2);
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
  <div class="max-w-md w-full card-grad rounded-3xl p-8 text-center shadow-2xl">

    <h1 class="font-display text-2xl font-black mb-1">Ujian Selesai!</h1>
    <p class="text-xs font-semibold mb-1" style="color:var(--gold)">
      <%= paket %> &middot; Try Out #<%= nomorTO %>
    </p>
    <p class="text-sm text-slate-500 mb-8">Hasil evaluasi belajar kamu sudah keluar.</p>

    <!-- Lingkaran skor -->
    <div class="skor-circle mx-auto mb-8">
      <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Skor Anda</span>
      <span class="text-6xl font-display font-black" style="color:var(--dark)"><%= skor %></span>
      <span class="text-xs font-bold" style="color:var(--gold)">/ 100</span>
    </div>

    <!-- Stats grid -->
    <div class="grid grid-cols-3 gap-3 mb-6">
      <div class="bg-white p-4 rounded-2xl border border-slate-100">
        <p class="text-[10px] font-bold uppercase text-slate-400">Benar</p>
        <p class="text-xl font-black text-green-600"><%= benar %></p>
      </div>
      <div class="bg-white p-4 rounded-2xl border border-slate-100">
        <p class="text-[10px] font-bold uppercase text-slate-400">Salah</p>
        <p class="text-xl font-black text-red-500"><%= totalSoal - benar %></p>
      </div>
      <div class="bg-white p-4 rounded-2xl border border-slate-100">
        <p class="text-[10px] font-bold uppercase text-slate-400">Total</p>
        <p class="text-xl font-black text-slate-700"><%= totalSoal %></p>
      </div>
    </div>

    <!-- Pesan berdasarkan skor -->
    <%
      let pesanSkor, warnaSkor;
      if (skor >= 80)      { pesanSkor = '🎉 Luar biasa! Pertahankan prestasimu.';        warnaSkor = '#15803d'; }
      else if (skor >= 60) { pesanSkor = '👍 Bagus! Terus tingkatkan lagi.';              warnaSkor = '#a16207'; }
      else                 { pesanSkor = '💪 Jangan menyerah, pelajari pembahasannya!';   warnaSkor = '#b91c1c'; }
    %>
    <p class="text-sm font-semibold mb-7 px-2" style="color:<%= warnaSkor %>"><%= pesanSkor %></p>

    <!-- Tombol aksi -->
    <div class="space-y-3">

      <a href="/ujian/review?nomor_to=<%= nomorTO %>&paket=<%= encodeURIComponent(paket) %>"
        class="block w-full py-4 rounded-xl font-bold text-sm text-center transition shadow-lg"
        style="background:linear-gradient(135deg,#5a0a0a,#7a1a1a);color:#c8a020">
        📝 Lihat Pembahasan Jawaban
      </a>

      <a href="/dashboardPembayaranUjian"
        class="block w-full py-3.5 rounded-xl font-bold text-sm text-center transition"
        style="background:white;color:var(--dark);border:1.5px solid #e8dec9">
        ← Kembali ke Dashboard
      </a>

      <p class="text-[10px] text-slate-400 italic pt-1">
        Nilai ini telah disimpan secara permanen di database.
      </p>
    </div>

  </div>
</body>
</html>
