<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Profil - Tabeahan Cendekia</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    :root { --gold:#c8a020; --dark:#7a1010; --cream:#fff8f8; --muted:#9b6b6b; --red-deep:#5a0a0a; }
    body  { font-family:'DM Sans',sans-serif; background:var(--cream); }
    .font-display { font-family:'Playfair Display',serif; }
    .acc-body { display:none; }
    .acc-body.open { display:block; }
    .chevron { transition:transform .25s; }
    .chevron.open { transform:rotate(180deg); }
  </style>
</head>
<body class="min-h-screen" style="color:var(--dark)">

<!-- ── NAVBAR ── -->
<nav class="sticky top-0 z-50 shadow-md" style="background:var(--red-deep);border-bottom:1px solid rgba(200,160,32,.25)">
  <div class="max-w-2xl mx-auto px-4 py-3 flex justify-between items-center">
    <div class="flex items-center gap-2.5">
      <img src="/asset/logo.png" alt="Logo" class="h-8 w-8 rounded-full object-cover"/>
      <span class="font-display font-bold text-sm text-white">
        Tabeahan <span style="color:var(--gold)">Cendekia</span>
      </span>
    </div>
    <a href="/dashboardPembayaranUjian"
       class="text-[11px] font-bold px-3 py-1.5 rounded transition"
       style="background:rgba(255,255,255,.08);color:rgba(255,255,255,.75);border:1px solid rgba(255,255,255,.15)"
       onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='rgba(255,255,255,.75)'">
      ← Kembali
    </a>
  </div>
</nav>

<!-- ── MAIN ── -->
<main class="max-w-2xl mx-auto px-4 py-8 space-y-4">

  <!-- Avatar + Nama -->
  <div class="flex items-center gap-4">
    <div class="w-14 h-14 rounded-full flex items-center justify-center font-display font-black text-2xl text-white flex-shrink-0"
         style="background:linear-gradient(135deg,var(--red-deep),#6b1a1a)">
      <%= user.username.charAt(0).toUpperCase() %>
    </div>
    <div>
      <h1 class="font-display font-black text-2xl leading-tight"><%= user.username %></h1>
      <p class="text-sm" style="color:var(--muted)"><%= user.email %></p>
    </div>
  </div>

  <!-- ── INFO AKUN ── -->
  <div class="bg-white rounded-xl border overflow-hidden" style="border-color:#f0e8d8">
    <div class="px-4 py-2.5 flex items-center gap-2" style="background:linear-gradient(135deg,var(--red-deep),#6b1a1a)">
      <span class="text-white font-display font-bold text-sm"> Info Akun</span>
    </div>
    <div class="divide-y px-5" style="divide-color:#f0e8d8">
      <% [
        { label:'Username', val: user.username },
        { label:'Email', val: user.email },
        { label:'ID Akun', val: '' + user.id, mono: true },
      ].forEach(row => { %>
      <div class="flex justify-between items-center py-2.5">
        <span class="text-xs" style="color:var(--muted)"><%= row.label %></span>
        <span class="text-sm font-bold <%= row.mono ? 'font-mono' : '' %>"><%= row.val %></span>
      </div>
      <% }) %>
      <div class="flex justify-between items-center py-2.5">
        <span class="text-xs" style="color:var(--muted)">Status Ujian</span>
        <span class="text-[10px] font-black uppercase px-2 py-0.5 rounded"
          style="background:<%= user.status_ujian==='SEDANG_UJIAN'?'rgba(234,179,8,.12)':'rgba(155,107,107,.08)' %>;
                 color:<%= user.status_ujian==='SEDANG_UJIAN'?'#a16207':'var(--muted)' %>">
          <%= user.status_ujian || 'IDLE' %>
        </span>
      </div>
      <% if (user.is_anggota) { %>
      <div class="flex justify-between items-center py-2.5">
        <span class="text-xs" style="color:var(--muted)">Tipe Akun</span>
        <span class="text-[10px] font-black px-2 py-0.5 rounded"
              style="background:rgba(21,128,61,.1);color:#15803d"> Anggota Kelas Offline</span>
      </div>
      <% } %>
    </div>
  </div>

  <!-- ── STATISTIK ── -->
  <% if (typeof riwayatUjian !== 'undefined' && riwayatUjian.length > 0) { %>
  <%
    const totalSesi = riwayatUjian.length;
    const skorMax = Math.max(...riwayatUjian.map(r => r.skor || 0));
    const skorAvg = Math.round(riwayatUjian.reduce((a,r) => a+(r.skor||0), 0) / totalSesi);
    const totalLulus  = riwayatUjian.filter(r => r.statusPG === 'LULUS').length;
    const skorColor = s => s >= 311 ? '#16a34a' : s >= 150 ? 'var(--gold)' : '#b91c1c';
  %>
  <div class="grid grid-cols-4 gap-3">
    <% [
      { label:'Total Sesi',   val: totalSesi,  color:'var(--dark)' },
      { label:'Skor Terbaik', val: skorMax,    color: skorColor(skorMax) },
      { label:'Rata-rata',    val: skorAvg,    color: skorColor(skorAvg) },
      { label:'Lulus PG',     val: totalLulus, color: totalLulus > 0 ? '#16a34a' : 'var(--muted)' },
    ].forEach(s => { %>
    <div class="bg-white rounded-xl border p-3 text-center" style="border-color:#f0e8d8">
      <p class="text-[9px] font-bold uppercase tracking-widest mb-1" style="color:var(--muted)"><%= s.label %></p>
      <p class="font-display font-black text-2xl" style="color:<%= s.color %>"><%= s.val %></p>
    </div>
    <% }) %>
  </div>
  <% } %>

  <!-- ── RANKING ── -->
  <% if (typeof paketGroups !== 'undefined') { %>
  <%
    const paketNames  = Object.keys(paketGroups);
    let totalPeserta  = 0, skorTertinggi = 0;
    paketNames.forEach(n => {
      const rows = paketGroups[n];
      totalPeserta += rows.length;
      if (rows.length && rows[0].total_skor > skorTertinggi) skorTertinggi = rows[0].total_skor;
    });
  %>

    <!-- ── RIWAYAT UJIAN ── -->
  <div class="bg-white rounded-xl border overflow-hidden" style="border-color:#f0e8d8">
    <div class="px-4 py-2.5 flex items-center justify-between" style="background:linear-gradient(135deg,var(--red-deep),#6b1a1a)">
      <span class="text-white font-display font-bold text-sm"> Riwayat Ujian</span>
      <% if (typeof riwayatUjian !== 'undefined' && riwayatUjian.length > 0) { %>
        <span class="text-[10px] font-bold px-2 py-0.5 rounded-full"
              style="background:rgba(255,255,255,.12);color:rgba(255,255,255,.6)">
          <%= riwayatUjian.length %> sesi
        </span>
      <% } %>
    </div>

    <% if (typeof riwayatUjian !== 'undefined' && riwayatUjian.length > 0) { %>
    <div>
      <% riwayatUjian.forEach((r, idx) => {
        let pgCls, pgTxt;
        if      (r.statusPG==='LULUS')       { pgCls='bg-green-50 text-green-700 border-green-200';  pgTxt='LULUS'; }
        else if (r.statusPG==='TIDAK_LULUS') { pgCls='bg-red-50 text-red-700 border-red-200';        pgTxt='TIDAK LULUS'; }
        else if (r.statusPG==='INFO')        { pgCls='bg-amber-50 text-amber-700 border-amber-200';  pgTxt='Indikatif'; }
        else                                 { pgCls='bg-blue-50 text-blue-700 border-blue-200';     pgTxt='Peringkat'; }
        const sColor = r.skor>=311?'#16a34a':r.skor>=150?'var(--gold)':'#b91c1c';
      %>
      <div class="<%= idx > 0 ? 'border-t' : '' %>" style="border-color:#f0e8d8">

        <!-- Accordion header -->
        <div class="flex items-center gap-3 px-4 py-3 cursor-pointer hover:bg-orange-50 transition"
             onclick="toggleAcc(<%= idx %>)">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="font-bold text-sm"><%= r.paket %></span>
              <span class="text-[9px] font-black uppercase px-1.5 py-0.5 rounded border <%= pgCls %>"><%= pgTxt %></span>
            </div>
            <p class="text-[11px] mt-0.5 flex items-center gap-1.5 flex-wrap" style="color:var(--muted)">
              <span>TO <%= r.nomor_to %></span>
              <span>·</span>
              <span><%= r.jml_benar %>/<%= r.jml_soal %> benar</span>
              <span>·</span>
              <span><%= r.tgl_selesai ? new Date(r.tgl_selesai).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) : '-' %></span>
              <% if (r.nilaiAkhir !== null && r.nilaiAkhir !== undefined) { %>
                <span>·</span>
                <span class="font-bold" style="color:var(--gold)"><%= r.nilaiAkhir %>%</span>
              <% } %>
              <%
                if (r.payment_created_at) {
                  const diff = (new Date(r.payment_created_at).getTime() + 7*24*60*60*1000) - Date.now();
                  if (diff > 0) {
                    const d = Math.floor(diff/(1000*60*60*24));
                    const h = Math.floor((diff%(1000*60*60*24))/(1000*60*60));
              %>
                <span>·</span>
                <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-amber-50 text-amber-600 border border-amber-200">⏳ sisa <%= d>0?d+'h '+h+'j':h+'j' %></span>
              <% } else { %>
                <span>·</span>
                <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-red-50 text-red-600 border border-red-200">🔒 Kadaluarsa</span>
              <% } } %>
            </p>
          </div>
          <!-- Skor + Review + Chevron -->
          <div class="flex items-center gap-2.5 flex-shrink-0">
            <div class="text-right">
              <p class="font-display font-black text-lg" style="color:<%= sColor %>"><%= r.skor %></p>
              <p class="text-[9px]" style="color:var(--muted)">skor</p>
            </div>
            <a href="/ujian/review?nomor_to=<%= r.nomor_to %>&paket=<%= encodeURIComponent(r.paket) %>"
               onclick="event.stopPropagation()"
               class="text-[10px] font-bold px-2 py-1 rounded transition whitespace-nowrap"
               style="background:rgba(90,10,10,.07);color:var(--dark);border:1px solid rgba(90,10,10,.15)"
               onmouseover="this.style.background='var(--red-deep)';this.style.color='var(--gold)'"
               onmouseout="this.style.background='rgba(90,10,10,.07)';this.style.color='var(--dark)'">
                Review
            </a>
            <span class="chevron text-[10px]" style="color:var(--muted)" id="chev-<%= idx %>">▼</span>
          </div>
        </div>



        <!-- Subtest detail -->
        <div class="acc-body" id="acc-<%= idx %>">
          <% if (r.subtests && r.subtests.length > 0) { %>
          <div class="px-4 pb-3 pt-1" style="background:#fdfaf5;border-top:1px solid #f0e8d8">
            <p class="text-[9px] font-bold uppercase tracking-widest mb-2" style="color:var(--muted)">Skor Per Subtest</p>
            <% r.subtests.forEach(sub => {
              const persen = sub.skor_maks > 0 ? Math.min(Math.round(sub.skor_subtest/sub.skor_maks*100),100) : 0;
              const barColor = (r.statusPG==='LULUS'||r.statusPG==='TIDAK_LULUS')
                ? (sub.lulus ? '#16a34a' : '#dc2626')
                : r.statusPG==='INFO'
                  ? (persen>=70?'#16a34a':'var(--gold)')
                  : '#1d4ed8';
            %>
            <div class="flex items-center gap-2 py-1.5 border-b border-dashed last:border-0" style="border-color:#f0e8d8">
              <div class="min-w-[110px] max-w-[130px]">
                <p class="text-[10px] font-bold truncate"><%= sub.nama_materi %></p>
                <% if ((r.statusPG==='LULUS'||r.statusPG==='TIDAK_LULUS') && sub.min_skor) { %>
                  <p class="text-[9px]" style="color:var(--muted)">min <%= sub.min_skor %></p>
                <% } %>
              </div>
              <div class="flex-1 h-1.5 rounded-full overflow-hidden" style="background:#f0e8d8">
                <div class="h-full rounded-full" style="width:<%= persen %>%;background:<%= barColor %>"></div>
              </div>
              <span class="text-[10px] font-bold font-mono text-right" style="min-width:60px;color:var(--dark)">
                <%= sub.skor_subtest %><span style="color:var(--muted);font-weight:400">/<%= sub.skor_maks %></span>
              </span>
              <% if (r.statusPG==='LULUS'||r.statusPG==='TIDAK_LULUS') { %>
                <span class="text-[10px]"><%= sub.lulus?'✅':'❌' %></span>
              <% } %>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <div class="px-4 py-3 text-center" style="background:#fdfaf5;border-top:1px solid #f0e8d8">
            <p class="text-xs" style="color:var(--muted)">Data subtest tidak tersedia (ujian lama).</p>
          </div>
          <% } %>
        </div>

      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div class="py-10 text-center">
      <p class="text-4xl opacity-20 mb-3">📋</p>
      <p class="text-sm font-semibold" style="color:var(--muted)">Belum ada riwayat ujian.</p>
      <a href="/dashboardPembayaranUjian" class="inline-block mt-3 text-xs font-bold" style="color:var(--gold)">
        Mulai ujian pertamamu →
      </a>
    </div>
    <% } %>
  </div>

  
  <!-- Header + mini stats -->
  <div class="bg-white rounded-xl border overflow-hidden" style="border-color:#f0e8d8">
    <div class="px-4 py-2.5 flex items-center justify-between" style="background:linear-gradient(135deg,var(--red-deep),#6b1a1a)">
      <span class="text-white font-display font-bold text-sm"> Ranking Ujian</span>
      <span class="text-[10px]" style="color:rgba(255,255,255,.45)">Peringkat berdasarkan skor tertinggi</span>
    </div>
    <div class="grid grid-cols-2 divide-x border-b" style="divide-color:#f0e8d8;border-color:#f0e8d8">
      <div class="py-3 text-center">
        <p class="text-[9px] font-bold uppercase tracking-widest mb-0.5" style="color:var(--muted)">Total Peserta</p>
        <p class="font-display font-black text-xl" style="color:var(--dark)"><%= totalPeserta %></p>
      </div>
      <div class="py-3 text-center">
        <p class="text-[9px] font-bold uppercase tracking-widest mb-0.5" style="color:var(--muted)">Skor Tertinggi</p>
        <p class="font-display font-black text-xl" style="color:var(--gold)"><%= skorTertinggi || '—' %></p>
      </div>
    </div>
  </div>

  <!-- Grid 3 kolom per paket (sama persis dengan aslinya) -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    <% paketNames.forEach(paketName => { %>
    <% const rankings = paketGroups[paketName]; %>
    <div class="bg-white rounded-xl border overflow-hidden" style="border-color:#f0e8d8">

      <!-- Paket header -->
      <div class="flex items-center gap-2 px-3 py-2.5 border-b" style="background:#fcf5f5;border-color:#f0e8d8">
        <div class="w-2 h-2 rounded-full flex-shrink-0" style="background:var(--gold)"></div>
        <p class="font-display font-bold text-sm flex-1 truncate" style="color:var(--red-deep)"><%= paketName %></p>
        <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-white border" style="color:var(--muted);border-color:#f0e8d8">
          <%= rankings.length %> peserta
        </span>
      </div>

      <!-- Rank list -->
      <% if (rankings.length === 0) { %>
        <div class="py-8 text-center">
          <p class="text-2xl opacity-20 mb-1">📋</p>
          <p class="text-xs" style="color:var(--muted)">Belum ada data</p>
        </div>
      <% } else { %>
        <% rankings.forEach((r, i) => { %>
        <div class="flex items-center gap-2 px-3 py-2 border-b last:border-0 text-sm"
             style="border-color:#f0e8d8;background:<%= i===0?'#fefaec':i===1?'#f9f9f9':i===2?'#fdf7f0':'white' %>">
          <!-- Nomor / medali -->
          <div class="w-5 text-center flex-shrink-0 font-black text-sm">
            <%= i===0?'1':i===1?'2':i===2?'3':'<span style=color:var(--muted);font-size:10px>'+(i+1)+'</span>' %>
          </div>
          <!-- Avatar -->
          <div class="w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-black text-white flex-shrink-0"
               style="background:<%= i===0?'#b8860b':i===1?'#888':i===2?'#a0522d':'var(--red-deep)' %>">
            <%= r.username.charAt(0).toUpperCase() %>
          </div>
          <!-- Info -->
          <div class="flex-1 min-w-0">
            <p class="font-bold text-xs truncate"><%= r.username %></p>
            <p class="text-[9px]" style="color:var(--muted)"><%= r.jml_benar %>/<%= r.jml_soal %> benar</p>
          </div>
          <!-- TO -->
          <span class="text-[9px] font-bold px-1.5 py-0.5 rounded flex-shrink-0"
                style="background:rgba(21,128,61,.1);color:#15803d;border:1px solid rgba(21,128,61,.2)">
            TO <%= r.nomor_to %>
          </span>
          <!-- Skor -->
          <span class="font-display font-black text-sm flex-shrink-0"
                style="color:<%= i===0?'var(--gold)':'var(--dark)' %>"><%= r.total_skor %></span>
        </div>
        <% }) %>
      <% } %>
    </div>
    <% }) %>

    <!-- Isi kolom kosong kalau paket < 3 -->
    <% for (let i = paketNames.length; i < 3; i++) { %>
    <div class="bg-white rounded-xl border overflow-hidden opacity-40" style="border-color:#f0e8d8">
      <div class="flex items-center gap-2 px-3 py-2.5 border-b" style="background:#fcf5f5;border-color:#f0e8d8">
        <div class="w-2 h-2 rounded-full" style="background:#ccc"></div>
        <p class="font-display font-bold text-sm" style="color:#bbb">—</p>
      </div>
      <div class="py-8 text-center">
        <p class="text-xs" style="color:#ccc">Belum ada data</p>
      </div>
    </div>
    <% } %>
  </div>
  <% } %>


  <!-- ── ZONA BAHAYA ── -->
  <div class="bg-white rounded-xl border p-4" style="border-color:#f0e8d8">
    <p class="text-[11px] mb-3" style="color:var(--muted)">⚠️ Tindakan di bawah tidak dapat dibatalkan.</p>
    <form action="/deleteAccount" method="POST" class="confirm-hapus">
      <input type="hidden" name="id" value="<%= user.id %>">
      <button type="submit"
              class="text-xs font-bold px-4 py-2 rounded transition"
              style="background:none;border:1px solid rgba(220,38,38,.25);color:#b91c1c"
              onmouseover="this.style.background='rgba(220,38,38,.06)'"
              onmouseout="this.style.background='none'">
        🗑️ Hapus Akun Permanen
      </button>
    </form>
  </div>

  <p class="text-center text-[10px] font-bold uppercase tracking-widest pb-4" style="color:rgba(155,107,107,.35)">
    Tabeahan Cendekia
  </p>

</main>

<script>
  // Riwayat ujian accordion
  function toggleAcc(idx) {
    const body = document.getElementById('acc-' + idx);
    const chev = document.getElementById('chev-' + idx);
    const open = body.classList.toggle('open');
    chev.classList.toggle('open', open);
  }

  // Konfirmasi hapus akun
  document.querySelectorAll('.confirm-hapus').forEach(form => {
    form.addEventListener('submit', e => {
      if (!confirm('⚠️ Akun akan dihapus PERMANEN beserta semua data ujian!\nTindakan ini tidak bisa dibatalkan.\n\nYakin?'))
        e.preventDefault();
    });
  });
</script>
</body>
</html>
